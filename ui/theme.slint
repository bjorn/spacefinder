// App theme: dark color palette plus common layout tokens.
export global Theme {
    out property <color> bg: #1b1b1d;
    out property <color> bg-component: #242427;
    out property <color> bg-elevated: #2c2c2f;
    out property <color> bg-hover: #34343a;
    out property <color> bg-pressed: #3d3d44;
    out property <color> border: #3a3a3c;
    out property <color> border-strong: #4d4d52;
    out property <color> text: #e5e5e5;
    out property <color> text-muted: #a0a0a5;
    out property <color> text-subtle: #77777c;
    out property <color> accent: #62a0ea;
    out property <color> accent-hover: #7ab0ee;
    out property <color> accent-pressed: #4d8cd6;
    out property <color> selection-bg: #2e496b;
    out property <color> selection-bg-inactive: #353a42;
    out property <color> divider: #2e2e31;
    out property <color> danger: #e06c75;
    out property <length> radius: 8px;
    out property <length> radius-small: 4px;
    out property <length> padding: 8px;
    out property <length> padding-small: 4px;
    out property <length> padding-large: 12px;
    out property <length> row-height: 32px;
    out property <length> grid-tile: 104px;
    out property <length> header-height: 44px;
    out property <length> sidebar-width: 224px;
}
