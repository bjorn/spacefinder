import { Theme } from "theme.slint";

// Shared cell rectangle used by the columns and treemap views. Both
// render a grid of these: a double-outlined box, bold when the entry
// is a directory, muted while a size recompute is pending, and a
// two-part label where the size text is a touch dimmer than the name
// so the name reads first.
export component CellRect inherits Rectangle {
    in property <string> name;
    in property <string> size-text;
    in property <bool> is-dir;
    in property <bool> pending;
    in property <bool> selected;
    // File-type category fill color. Only applied when `colorize` is
    // true (the treemap opts in; the columns view leaves it off).
    in property <color> category-color;
    in property <bool> colorize: false;
    // Stack the size below the name on a second row, both left-aligned.
    // The treemap uses this layout; its wide-but-short tiles read more
    // naturally with the label on two rows than with the size right-
    // aligned far from the name.
    in property <bool> stacked: false;

    // Tiles shorter than two lines would otherwise bleed their label
    // past the cell border. Clipping the root keeps that contained.
    clip: true;

    callback clicked(bool /* ctrl-held */);
    callback double-clicked();
    // Screen-relative (x, y) so callers can forward directly to the
    // context-menu plumbing without further offsetting.
    callback right-clicked(length, length);

    // Subtle inner stroke that sits 1px inside the outer border,
    // making adjacent cells visually more distinct.
    Rectangle {
        x: 1px;
        y: 1px;
        width: parent.width - 3px;
        height: parent.height - 3px;
        border-width: 1.5px;
        border-color: Theme.border;
        border-radius: 2px;
        // File tiles in colorize mode are tinted by their type category.
        // At rest the category color is mixed heavily toward the dark
        // background so the white name/size labels stay legible; on hover
        // it brightens to a more saturated shade of the same category
        // color (instead of the generic gray) for clearer feedback.
        // Directories and non-colorized cells keep the neutral fills and
        // the gray hover. Selection and press still win.
        property <bool> tinted: root.colorize && !root.is-dir;
        property <color> rest-fill: tinted
            ? root.category-color.mix(Theme.bg-component, 30%)
            : (root.is-dir ? Theme.bg-elevated : Theme.bg-component);
        property <color> hover-fill: tinted
            ? root.category-color.mix(Theme.bg-component, 40%)
            : Theme.bg-hover;
        background: root.selected
            ? Theme.selection-bg
            : touch.pressed
                ? Theme.bg-pressed
                : touch.has-hover
                    ? hover-fill
                    : rest-fill;
    }

    // Name label. Inline mode: claims the space to the left of the
    // size label, eliding first when tight. Stacked mode: full row,
    // intrinsic one-line height.
    //
    // Two Text elements are unavoidable (Slint Text is single-color)
    // but we position them absolutely rather than via a layout — with
    // hundreds of tiles the layout pass dominates frame cost.
    name-label := Text {
        x: 6px;
        y: 3px;
        width: root.stacked
            ? max(0px, parent.width - 12px)
            : max(0px, size-label.x - self.x - 4px);
        height: root.stacked
            ? self.preferred-height
            : max(0px, parent.height - 6px);
        text: root.name;
        color: root.pending ? Theme.text-subtle : Theme.text;
        font-size: 11px;
        font-weight: root.is-dir ? 600 : 400;
        overflow: elide;
        wrap: no-wrap;
        vertical-alignment: top;
    }

    // Size label. Inline mode: intrinsic width, right-aligned. Stacked
    // mode: left-aligned on the row below the name. Size's stacked-y
    // rides on the name's intrinsic height so a future font-size tweak
    // or script-specific metrics land correctly with no extra knob.
    size-label := Text {
        x: root.stacked ? 6px : max(6px, parent.width - self.width - 6px);
        y: root.stacked ? (name-label.y + name-label.height + 1px) : 3px;
        width: root.stacked
            ? max(0px, parent.width - 12px)
            : self.preferred-width;
        height: root.stacked
            ? max(0px, parent.height - self.y - 3px)
            : max(0px, parent.height - 6px);
        text: root.size-text;
        color: root.pending ? Theme.text-subtle : Theme.text-muted;
        font-size: 11px;
        font-weight: root.is-dir ? 600 : 400;
        overflow: elide;
        wrap: no-wrap;
        vertical-alignment: top;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        // Latch the modifier bits on every pointer-event so the later
        // `clicked` handler has them, mirroring the file_grid.slint
        // GridTile pattern.
        property <bool> ctrl-held: false;
        pointer-event(ev) => {
            self.ctrl-held = ev.modifiers.control;
            if (ev.button == PointerEventButton.right && ev.kind == PointerEventKind.down) {
                root.right-clicked(
                    self.mouse-x + root.absolute-position.x,
                    self.mouse-y + root.absolute-position.y,
                );
            }
        }
        clicked => {
            root.clicked(self.ctrl-held);
        }
        double-clicked => {
            root.double-clicked();
        }
    }
}
