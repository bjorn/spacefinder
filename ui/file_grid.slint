import { LineEdit, ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { FileItem, FileListState } from "file_list.slint";

component GridTile inherits Rectangle {
    in property <FileItem> item;
    in property <int> index;
    in property <bool> editing: false;
    callback clicked(int, bool, bool);
    callback double-clicked(int);
    callback right-clicked(int, length, length);
    callback rename-submitted(int, string);
    callback rename-cancelled();

    width: 104px;
    height: 120px;
    border-radius: Theme.radius-small;
    background: root.item.selected
        ? Theme.selection-bg
        : touch.has-hover ? Theme.bg-hover : transparent;

    VerticalLayout {
        padding: 6px;
        spacing: 4px;
        alignment: start;
        VerticalLayout {
            alignment: center;
            height: 64px;
            Rectangle {
                HorizontalLayout {
                    alignment: center;
                    Image {
                        source: root.item.icon;
                        width: 56px;
                        height: 56px;
                        image-fit: contain;
                    }
                }
            }
        }
        if !root.editing : Text {
            text: root.item.name;
            color: root.item.cut ? Theme.text-subtle : Theme.text;
            horizontal-alignment: center;
            overflow: elide;
            wrap: word-wrap;
            font-size: 12px;
        }
        if root.editing : LineEdit {
            height: 24px;
            text: FileListState.editing-text;
            accepted(t) => {
                root.rename-submitted(root.index, t);
            }
        }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        enabled: !root.editing;
        property <bool> ctrl-held: false;
        property <bool> shift-held: false;
        pointer-event(ev) => {
            self.ctrl-held = ev.modifiers.control;
            self.shift-held = ev.modifiers.shift;
            if (ev.button == PointerEventButton.right && ev.kind == PointerEventKind.down) {
                root.right-clicked(root.index, self.mouse-x + root.x, self.mouse-y + root.y);
            }
        }
        clicked => {
            root.clicked(root.index, self.ctrl-held, self.shift-held);
        }
        double-clicked => { root.double-clicked(root.index); }
    }
}

export component FileGridView inherits Rectangle {
    in property <[FileItem]> items;
    callback item-clicked(int, bool, bool);
    callback item-double-clicked(int);
    callback item-right-clicked(int, length, length);
    callback background-right-clicked(length, length);
    callback background-clicked();
    callback rename-submitted(int, string);
    callback rename-cancelled();

    // Reactive grid geometry. cols is derived from the view width, so the
    // layout reflows as the window (and therefore this view) is resized.
    // Rust recomputes its own column count from the window size in
    // `handle_key` using the same formula below, so this property is
    // internal-only and not exposed as `out`.
    property <length> tile-w: 110px;
    property <length> tile-h: 124px;
    property <length> h-padding: 8px;
    property <int> cols: max(1, floor((self.width - 2 * root.h-padding) / root.tile-w));
    property <int> row-count: (items.length + cols - 1) / cols;

    background: Theme.bg;

    // Background touch catcher (right-click to open the empty-area menu).
    TouchArea {
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right) {
                root.background-right-clicked(self.mouse-x, self.mouse-y);
            }
        }
        clicked => { root.background-clicked(); }
    }

    ScrollView {
        // ScrollView renders a real vertical scrollbar, unlike bare Flickable.
        // Pin viewport-width to self.width so no horizontal scrollbar appears;
        // the column math below reads root.width, which the ScrollView shrinks
        // to account for the vertical scrollbar gutter, so tiles do not clip.
        viewport-width: self.width;
        viewport-height: max(self.height, root.row-count * root.tile-h + 8px);

        // All tiles are instantiated. Row-level virtualization is lost
        // compared to the previous ListView design, but typical cleanup
        // workloads are a few hundred to a few thousand items which handles
        // fine. The win is live column reflow driven entirely from Slint.
        for item[i] in root.items : GridTile {
            x: root.h-padding + mod(i, root.cols) * root.tile-w;
            y: 4px + floor(i / root.cols) * root.tile-h;
            item: item;
            index: i;
            editing: FileListState.editing-index == i;
            clicked(idx, ctrl, shift) => {
                root.item-clicked(idx, ctrl, shift);
            }
            double-clicked(idx) => { root.item-double-clicked(idx); }
            right-clicked(idx, x, y) => {
                root.item-right-clicked(idx, x, y);
            }
            rename-submitted(idx, name) => {
                FileListState.editing-index = -1;
                root.rename-submitted(idx, name);
            }
            rename-cancelled => {
                FileListState.editing-index = -1;
                root.rename-cancelled();
            }
        }
    }
}
