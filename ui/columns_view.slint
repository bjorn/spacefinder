import { Theme } from "theme.slint";
import { CellRect } from "cell_rect.slint";

export struct ColumnCell {
    name: string,
    size-text: string,
    col: int,
    y-start: float,
    y-end: float,
    is-dir: bool,
    pending: bool,
    path: string,
    is-root: bool,
    selected: bool,
}

export component ColumnsView inherits Rectangle {
    in property <[ColumnCell]> cells;
    in property <int> visible-columns: 5;
    // Single left-click: select the cell.
    callback cell-clicked(string);
    // Double left-click: zoom in (dir) or go up (root).
    callback cell-double-clicked(string, bool, bool);
    // Right-click: open the context menu at screen-relative (x, y).
    callback cell-right-clicked(string, length, length);

    background: Theme.bg;

    property <length> h-pad: 4px;
    property <length> col-spacing: 2px;
    // Total padding to subtract from the available width.
    property <length> content-w: max(0px, self.width - 2 * root.h-pad);
    property <length> col-w: (root.content-w - (root.visible-columns - 1) * root.col-spacing) / root.visible-columns;

    // Inner Rectangle wraps the absolutely-positioned children so they
    // cannot feed back into the root's intrinsic-size inference during
    // the first binding pass. Its explicit width/height make it the
    // coordinate system the cells live inside. Cells derive their pixel
    // positions from this rectangle's live height, so a window resize
    // reflows every cell with zero Rust round-trip.
    inner := Rectangle {
        width: parent.width;
        height: parent.height;

        for cell in root.cells : CellRect {
            x: root.h-pad + cell.col * (root.col-w + root.col-spacing);
            y: root.h-pad + cell.y-start * inner.height;
            width: root.col-w;
            height: max(0px, (cell.y-end - cell.y-start) * inner.height);

            name: cell.name;
            size-text: cell.size-text;
            is-dir: cell.is-dir;
            pending: cell.pending;
            selected: cell.selected;

            clicked(_ctrl) => { root.cell-clicked(cell.path); }
            double-clicked => { root.cell-double-clicked(cell.path, cell.is-dir, cell.is-root); }
            right-clicked(x, y) => { root.cell-right-clicked(cell.path, x, y); }
        }
    }
}
