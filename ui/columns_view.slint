import { Theme } from "theme.slint";

export struct ColumnCell {
    name: string,
    size-text: string,
    col: int,
    y-start: float,
    y-end: float,
    is-dir: bool,
    pending: bool,
    path: string,
    is-root: bool,
    selected: bool,
}

export component ColumnsView inherits Rectangle {
    in property <[ColumnCell]> cells;
    in property <int> visible-columns: 5;
    // Single left-click: select the cell.
    callback cell-clicked(string);
    // Double left-click: zoom in (dir) or go up (root).
    callback cell-double-clicked(string, bool, bool);
    // Right-click: open the context menu at screen-relative (x, y).
    callback cell-right-clicked(string, length, length);

    background: Theme.bg;

    property <length> h-pad: 4px;
    property <length> col-spacing: 2px;
    // Total padding to subtract from the available width.
    property <length> content-w: max(0px, self.width - 2 * root.h-pad);
    property <length> col-w: (root.content-w - (root.visible-columns - 1) * root.col-spacing) / root.visible-columns;

    // Inner Rectangle wraps the absolutely-positioned children so they
    // cannot feed back into the root's intrinsic-size inference during
    // the first binding pass. Its explicit width/height make it the
    // coordinate system the cells live inside. Cells derive their pixel
    // positions from this rectangle's live height, so a window resize
    // reflows every cell with zero Rust round-trip.
    inner := Rectangle {
        width: parent.width;
        height: parent.height;

        for cell in root.cells : Rectangle {
            x: root.h-pad + cell.col * (root.col-w + root.col-spacing);
            y: root.h-pad + cell.y-start * inner.height;
            width: root.col-w;
            height: max(0px, (cell.y-end - cell.y-start) * inner.height);
            border-width: 1px;
            border-color: Theme.divider;
            border-radius: 2px;
            background: cell.selected
                ? Theme.selection-bg
                : touch.pressed
                    ? Theme.bg-pressed
                    : touch.has-hover
                        ? Theme.bg-hover
                        : cell.is-dir ? Theme.bg-elevated : Theme.bg-component;
            clip: true;

            // Subtle inner stroke that sits 1px inside the outer border,
            // making vertically-stacked cells visually more distinct.
            Rectangle {
                x: 1px;
                y: 1px;
                width: parent.width - 2px;
                height: parent.height - 2px;
                border-width: 1px;
                border-color: Theme.border;
                border-radius: 1px;
                background: transparent;
            }

            Text {
                x: 4px;
                y: 2px;
                width: parent.width - 8px;
                height: parent.height - 4px;
                text: cell.name + (cell.size-text != "" ? "  " + cell.size-text : "");
                color: cell.pending ? Theme.text-subtle : Theme.text;
                font-size: 11px;
                font-weight: cell.is-dir ? 600 : 400;
                overflow: elide;
                wrap: no-wrap;
                vertical-alignment: top;
            }

            touch := TouchArea {
                mouse-cursor: pointer;
                pointer-event(ev) => {
                    if (ev.button == PointerEventButton.right && ev.kind == PointerEventKind.down) {
                        // Screen-relative coordinates, matching the
                        // list and grid views' convention.
                        root.cell-right-clicked(
                            cell.path,
                            self.mouse-x + parent.absolute-position.x,
                            self.mouse-y + parent.absolute-position.y,
                        );
                    }
                }
                clicked => {
                    root.cell-clicked(cell.path);
                }
                double-clicked => {
                    root.cell-double-clicked(cell.path, cell.is-dir, cell.is-root);
                }
            }
        }
    }
}
