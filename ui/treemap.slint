import { Theme } from "theme.slint";

export struct Tile {
    // Index into the controller's `filtered` slice. Shared with the
    // list and grid views so the same click handler and
    // `selection: FxHashSet<usize>` back all three views.
    index: int,
    name: string,
    size-text: string,
    is-dir: bool,
    pending: bool,
    selected: bool,
    // Fractional coords in [0, 1], relative to the view's usable area.
    // Rust computes these; the Slint side multiplies by the live inner
    // width/height so a window resize reflows with no round-trip.
    x: float,
    y: float,
    w: float,
    h: float,
}

export component TreemapView inherits Rectangle {
    in property <[Tile]> tiles;
    // Single left-click: select the tile (ctrl toggles within the
    // existing selection; shift is unused in the treemap because a
    // rectangular range doesn't map naturally onto squarified tiles).
    callback tile-clicked(int, bool);
    // Double left-click: directories drill down, files open in the OS.
    callback tile-double-clicked(int);
    // Right-click: open the context menu at view-relative (x, y).
    // Main.slint converts to screen coords, matching the list/grid
    // `item-right-clicked` convention.
    callback tile-right-clicked(int, length, length);
    // Clicks on the empty background clear the selection.
    callback background-clicked();
    callback background-right-clicked(length, length);

    background: Theme.bg;

    property <length> pad: 4px;

    // Background TouchArea beneath the tiles catches clicks that fall
    // through gaps or happen on an empty directory. Tiles are declared
    // after it, so they appear on top and receive their own events
    // first — matching the file_grid.slint layering convention.
    bg-touch := TouchArea {
        pointer-event(ev) => {
            if (ev.button == PointerEventButton.right && ev.kind == PointerEventKind.down) {
                root.background-right-clicked(self.mouse-x, self.mouse-y);
            }
        }
        clicked => { root.background-clicked(); }
    }

    // The inner rectangle's live width/height is the coordinate system
    // tiles live inside. Wrapping them like this keeps their
    // absolutely-positioned children from feeding back into the root's
    // intrinsic-size inference during the first binding pass.
    inner := Rectangle {
        x: root.pad;
        y: root.pad;
        width: max(0px, root.width - 2 * root.pad);
        height: max(0px, root.height - 2 * root.pad);

        for tile in root.tiles : Rectangle {
            x: tile.x * inner.width;
            y: tile.y * inner.height;
            width: max(0px, tile.w * inner.width);
            height: max(0px, tile.h * inner.height);

            // Subtle inner stroke that sits 1px inside the outer border,
            // matching the columns view's double-outline look so the
            // two visualizations stay visually consistent.
            Rectangle {
                x: 1px;
                y: 1px;
                width: parent.width - 3px;
                height: parent.height - 3px;
                border-width: 1.5px;
                border-color: Theme.border;
                border-radius: 2px;
                background: tile.selected
                    ? Theme.selection-bg
                    : touch.pressed
                        ? Theme.bg-pressed
                        : touch.has-hover
                            ? Theme.bg-hover
                            : tile.is-dir ? Theme.bg-elevated : Theme.bg-component;
            }

            Text {
                x: 6px;
                y: 3px;
                width: max(0px, parent.width - 12px);
                height: max(0px, parent.height - 6px);
                text: tile.name + (tile.size-text != "" ? "  " + tile.size-text : "");
                color: tile.pending ? Theme.text-subtle : Theme.text;
                font-size: 11px;
                font-weight: tile.is-dir ? 600 : 400;
                overflow: elide;
                wrap: no-wrap;
                vertical-alignment: top;
            }

            touch := TouchArea {
                mouse-cursor: pointer;
                // Latch the modifier bits on every pointer-event so the
                // later `clicked` handler has them, mirroring the
                // file_grid.slint GridTile pattern.
                property <bool> ctrl-held: false;
                pointer-event(ev) => {
                    self.ctrl-held = ev.modifiers.control;
                    if (ev.button == PointerEventButton.right && ev.kind == PointerEventKind.down) {
                        // Emit view-relative coordinates. Main.slint
                        // adds the TreemapView's absolute-position to
                        // turn these into screen coords before opening
                        // the context menu.
                        root.tile-right-clicked(
                            tile.index,
                            self.mouse-x + parent.x + inner.x,
                            self.mouse-y + parent.y + inner.y,
                        );
                    }
                }
                clicked => {
                    root.tile-clicked(tile.index, self.ctrl-held);
                }
                double-clicked => {
                    root.tile-double-clicked(tile.index);
                }
            }
        }
    }
}
